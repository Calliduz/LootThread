{
  "entities": {
    "User": {
      "title": "User",
      "description": "A user of the platform, either a Gamer or an Artist.",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "Firebase Auth UID" },
        "email": { "type": "string", "format": "email" },
        "displayName": { "type": "string" },
        "role": { "type": "string", "enum": ["gamer", "artist"] },
        "bio": { "type": "string" },
        "avatarUrl": { "type": "string", "format": "uri" },
        "payoutInfo": { "type": "string", "description": "Encrypted or handled via stripe, placeholder for now" }
      },
      "required": ["uid", "email", "role"]
    },
    "Product": {
      "title": "Product",
      "description": "A skin (apparel) or attachment (peripheral).",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "description": { "type": "string" },
        "price": { "type": "number" },
        "category": { "type": "string", "enum": ["skin", "attachment"] },
        "subCategory": { "type": "string", "description": "e.g., Mouse, Keyboard, T-Shirt" },
        "images": { "type": "array", "items": { "type": "string", "format": "uri" } },
        "artistId": { "type": "string", "description": "UID of the artist if category is skin" },
        "specs": { 
          "type": "object", 
          "description": "Technical specs for attachments (DPI, Weight, etc.)" 
        },
        "inventory": { "type": "integer" },
        "tags": { "type": "array", "items": { "type": "string" } },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "price", "category", "inventory"]
    },
    "Order": {
      "title": "Order",
      "description": "A purchase transaction.",
      "type": "object",
      "properties": {
        "buyerId": { "type": "string" },
        "items": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "productId": { "type": "string" },
              "quantity": { "type": "integer" },
              "priceAtPurchase": { "type": "number" },
              "artistId": { "type": "string" }
            }
          }
        },
        "totalAmount": { "type": "number" },
        "status": { "type": "string", "enum": ["pending", "processing", "shipped", "delivered"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["buyerId", "items", "totalAmount", "status"]
    },
    "Review": {
      "title": "Review",
      "description": "A user review for a product.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "userName": { "type": "string" },
        "userAvatar": { "type": "string" },
        "rating": { "type": "integer", "minimum": 1, "maximum": 5 },
        "comment": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "rating", "comment", "createdAt"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profiles"
    },
    "/products/{productId}": {
      "schema": "Product",
      "description": "Marketplace products"
    },
    "/products/{productId}/reviews/{reviewId}": {
      "schema": "Review",
      "description": "Product reviews"
    },
    "/orders/{orderId}": {
      "schema": "Order",
      "description": "Purchase records"
    }
  }
}
